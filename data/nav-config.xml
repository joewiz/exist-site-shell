<?xml version="1.0" encoding="UTF-8"?>
<!--
  Nav bar configuration for the eXist-db site shell.

  Controls what appears in the sitewide navigation bar.
  For app URL resolution (cross-references like {eXide}), see app-registry.xml.

  Entry types:
    <app abbrev="..." title="..."/>
        Shown only when the app is installed locally.
        URL is context-path + /apps/{abbrev}.

    <link title="..." href="https://..."/>  (external — opens in new tab)
    <link title="..." path="/apps/..."/>    (internal — prepended with context-path)
        Always shown regardless of what is installed.
-->
<nav-config xmlns="http://exist-db.org/site/nav">
    <app abbrev="dashboard" title="Dashboard"/>
    <app abbrev="docs"      title="Documentation"/>
    <app abbrev="notebook"  title="Notebook"/>
    <app abbrev="blog"      title="Blog"/>
    <link title="Community" path="/apps/exist-site-shell/community"/>
    <link title="Source"    href="https://github.com/eXist-db/exist"/>
</nav-config>
